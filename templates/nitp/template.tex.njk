\section{\textbf{Skills}}

\vspace{-0.4mm}
\resumeHeadingSkillStart

<% for s in skills %>
\resumeSubItem{<< s.category | texescape >> : }{<< s.items | join(", ") | texescape >>}
<% endfor %>
\resumeHeadingSkillEnd



