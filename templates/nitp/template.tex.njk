    {}
    {{}[<% if p.githubLink %>\href{<< p.githubLink | texescape >>}{\textcolor{black}{\faGithub}}<% endif %><% if p.githubLink and p.demoLink %> \ <% endif %><% if p.demoLink %>\href{<< p.demoLink | texescape >>}{\textcolor{black}{\faExternalLink*}}<% endif %>]}
